{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATHS\" 2>&1 | tail -5"
          },
          {
            "type": "command",
            "command": "npx eslint --fix \"$CLAUDE_FILE_PATHS\" 2>&1 | tail -10"
          },
          {
            "type": "command",
            "command": "npx tsc --noEmit --pretty 2>&1 | head -30"
          },
          {
            "type": "command",
            "command": "npx vitest related --run \"$CLAUDE_FILE_PATHS\" 2>&1 | tail -20"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/guard-paths.mjs"
          }
        ]
      }
    ]
  }
}
